nextflow_workflow {

    name "Test Subworkflow PREPARE_GENOME_METADATA"
    script "../main.nf"
    workflow "PREPARE_GENOME_METADATA"

    tag "subworkflows"
    tag "subworkflows_ensembl"
    tag "subworkflows/prepare_genome_metadata"

    test("genomesummary workflow test [stub]") {

        when {
            options "-stub"

            workflow {
                """
                input[0] = Channel.of('{ "genome": "test" }')
                    .collectFile(name: 'meta-query.json', newLine: true)
                    .combine(Channel.of('{ "reports": [] }')
                    .collectFile(name: 'ncbi_genome-summary.json', newLine: true))
                    .map { meta_query, genome_summary ->
                        [
                            [accession: 'GCA_000001215.4'],
                            meta_query,
                            genome_summary
                        ]
                    }
                """
            }
        }

        then {
            def prepared = workflow.out.prepared_metadata.get(0)
            def meta = prepared.get(0)
            def genome_json = path(prepared.get(1)).toFile()

            assertAll(
                { assert workflow.success },
                { assert meta.accession == "GCA_000001215.4" },
                { assert meta.has_annotation },
                { assert genome_json.text.contains('"accession": "GCA_000001215.4"') },
                { assert snapshot(workflow).match("workflow") },
            )
        }
    }
}
