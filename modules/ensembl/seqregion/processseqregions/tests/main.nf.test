// nf-core modules test seqregion/processseqregions
nextflow_process {

    name "Test Process SEQREGION_PROCESSSEQREGIONS"
    script "../main.nf"
    process "SEQREGION_PROCESSSEQREGIONS"

    tag "seqregion"
    tag "seqregion/processseqregions"

    test("Process sequence regions [stub]") {

        when {

            options "-stub"

                process {
                    """
                    input[0]= Channel.of('{ "genome": "test" }')
                    .collectFile(name: 'genome.json', newLine: true)
                    .combine(Channel.of('# Assembly report')
                    .collectFile(name: 'assembly_report.txt', newLine: true))
                    .combine(Channel.of('LOCUS test')
                    .collectFile(name: 'genome.gbff', newLine: true))
                    .map { json, report, gbff ->
                    [ [ test_id:'dummy_core_db_core_110_1', species:'Genus species'], json, report, gbff ]
                    }
                    """
                }
            }

            then {
                assertAll(
                    { assert process.success },
                    { assert snapshot(process.out).match() },
            )
        }
    }
}