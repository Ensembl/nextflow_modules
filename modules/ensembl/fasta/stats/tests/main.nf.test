nextflow_process {

    name "Test Process FASTA_STATS"
    script "../main.nf"
    process "FASTA_STATS"

    tag "modules"
    tag "modules_local"
    tag "fasta"
    tag "fasta/stats"

    test("Stub outputs stats tuple and versions") {

        when {
            options "-stub"

            process {
                """
                def fasta = file("input.fa")

                input[0] = [[ id:'test' ], fasta]
                """
            }
        }

        then {
            assert process.success
            assert process.trace.tasks().size() == 1
            assert process.out.stats.size() == 1
            
            def stats_out = process.out.stats[0]
            assert stats_out[0].id == "test"
            assert file(stats_out[1]).name == "input.stats.txt"
            assert snapshot(process.out).match()
        }
    }
}
