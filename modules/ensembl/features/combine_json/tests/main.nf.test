    }

    test("Real run: repeat manifest order is preserved") {

        when {
            process {
                """
                input[0] = [[ id:'test' ],
                            file('${moduleDir}/tests/data/repeat/order/manifest.txt'),
                            file('${projectDir}/modules/assets/NO_FILE')]
                """
