nextflow_process {

    name "Test Process FEATURES_CONVERTTOJSON"
    script "../main.nf"
    process "FEATURES_CONVERTTOJSON"

    tag "modules"
    tag "modules_local"
    tag "features"
    tag "features/converttojson"

    test("Stub wires TRF input mode") {

        when {
            options "-stub"

            process {
                """
                def featuresOut = file("test.out")
                featuresOut.text = "stub\\n"

                def noFile = file("NO_FILE")
                noFile.text = ""

                input[0] = [[ id:'test' ], featuresOut, noFile]
                input[1] = "trf"
                input[2] = "4.1.7"
                input[3] = "-species stub"
                input[4] = "stub_provider"
                input[5] = false
                """
            }
        }

        then {
            assert process.success
            assert process.out.json.size() == 1

            def jsonPath = process.out.json[0][1]
            def jsonFile = path(jsonPath).toFile()

            assert jsonFile.exists()
            assert jsonFile.name == "test.trf.features.json"
            assert process.out.json[0][0].id == "test"
            assert snapshot(process.out).match()
        }
    }

    test("Stub wires RepeatMasker Repbase input mode") {

        when {
            options "-stub"

            process {
                """
                def featuresOut = file("test.out")
                featuresOut.text = "stub\\n"

                def noFile = file("NO_FILE")
                noFile.text = ""

                input[0] = [[ id:'test' ], featuresOut, noFile]
                input[1] = "repeatmasker_rmlib"
                input[2] = "4.1.7"
                input[3] = "-species stub"
                input[4] = "stub_provider"
                input[5] = false
                """
            }
        }

        then {
            assert process.success
            assert process.out.json.size() == 1

            def jsonPath = process.out.json[0][1]
            def jsonFile = path(jsonPath).toFile()

            assert jsonFile.exists()
            assert jsonFile.name == "test.repeatmasker_rmlib.features.json"
            assert process.out.json[0][0].id == "test"
            assert snapshot(process.out).match()
        }
    }

    test("Stub wires RepeatMasker custom library input mode") {

        when {
            options "-stub"

            process {
                """
                def featuresOut = file("test.out")
                featuresOut.text = "stub\\n"

                def consensus = file("repeatmodeler.fa")
                consensus.text = ">consensus\\nACGT\\n"

                input[0] = [[ id:'test' ], featuresOut, consensus]
                input[1] = "repeatmask_customlib"
                input[2] = "4.1.7"
                input[3] = "-species stub"
                input[4] = "stub_provider"
                input[5] = true
                """
            }
        }

        then {
            assert process.success
            assert process.out.json.size() == 1

            def jsonPath = process.out.json[0][1]
            def jsonFile = path(jsonPath).toFile()

            assert jsonFile.exists()
            assert jsonFile.name == "test.repeatmask_customlib.features.json"
            assert process.out.json[0][0].id == "test"
            assert snapshot(process.out).match()
        }
    }
}
