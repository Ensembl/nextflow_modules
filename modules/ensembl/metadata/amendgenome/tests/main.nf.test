// nf-core modules test metadata/amendgenome
nextflow_process {

    name "Test Process METADATA_AMENDGENOME"
    script "../main.nf"
    process "METADATA_AMENDGENOME"

    tag "metadata/amendgenome"
    
    test("amendgenome (genome.json) - stub") {

        options "-stub"

        when {
            process {
                """
                input[0]= Channel.of('>chr1', 'ATGCATGC')
                    .collectFile(name: 'genome.fasta', newLine: true)
                    .combine(Channel.of('{ "genome": "test" }')
                    .collectFile(name: 'genome.json', newLine: true))
                    .combine(Channel.of('# Assembly report')
                    .collectFile(name: 'assembly_report.txt', newLine: true))
                    .combine(Channel.of('LOCUS test')
                    .collectFile(name: 'genome.gbff', newLine: true))
                    .map { fasta, json, report, gbff ->
                    [ [ id: 'test' ], json, report, fasta, gbff ]
                    }
                """
            }
        }
        then {
            assert process.success
            assert snapshot(process.out).match()
        }

    }
}