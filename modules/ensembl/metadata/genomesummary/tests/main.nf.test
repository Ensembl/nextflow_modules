// nf-core modules test metadata/genomesummary
nextflow_process {

    name "Test Process METADATA_GENOMESUMMARY"
    script "../main.nf"
    process "METADATA_GENOMESUMMARY"

    tag "metadata"
    tag "metadata/genomesummary"

    test("Metadata 'genome summary' [stub]") {
        
        when {
            options "-stub"
            process {
                """
                input[0] = Channel
                    .of('{ "genome": "test" }')
                    .collectFile(name: 'meta_query.json', newLine: true)
                    .combine(
                    Channel.of('summary test')
                    .collectFile(name: 'ncbi_genome_summary.json', newLine: true)
                ).map { meta_query, ncbi_genome_summary ->
                [ [ id: 'GCA_000001215.4' ], meta_query, ncbi_genome_summary ]
                }
            """
            }
        }
        then {   
            assertAll(
                    { assert process.success },
                    { assert snapshot(process.out.versions).match() },
            )
        }
    }

}
